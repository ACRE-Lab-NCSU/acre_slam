{
  /*** Keyframe-based VGICP odometry estimation ***
  // smoother_lag                : Fixed-lag smoothing window size [sec]
  // use_isam2_dogleg            : Use the dogleg optimizer as the backend of ISAM2 that is slow but more robust
  // isam2_relinearize_skip      :
  // isam2_relinearize_thresh    :
  */
  "odometry_estimation": {
    "so_name": "libodometry_estimation_cpu.so",
    // Do NOT set init_T_world_imu to compensate for the 13deg LiDAR/IMU mount
    // tilt: LOOSE init already estimates gravity direction from the raw IMU,
    // independent of mounting angle. Manually rotating this fights that
    // estimate instead of helping it.
    // Initialization params
    "initialization_mode": "LOOSE",
    // Widened from 3.0s: Go2 keeps making small balance-correction motions
    // even while "standing", which previously made LOOSE init pick up a
    // garbage gyro bias (observed ~3.6 rad/s in logs) when the window caught
    // that motion. More time gives it more chance to average it out.
    "initialization_window_size": 5.0,
    "init_pose_damping_scale": 1e10,
    // Optimizer params
    "smoother_lag": 5.0,
    "use_isam2_dogleg": false,
    "isam2_relinearize_skip": 1,
    "isam2_relinearize_thresh": 0.1,
    "fix_imu_bias": false,
    // Registration settings
    "registration_type": "GICP",
    "max_iterations": 8,
    "lru_thresh": 100,
    "target_downsampling_rate": 0.1,
    // GICP + iVox params
    "ivox_resolution": 1.0,
    "ivox_min_dist": 0.1,
    // VGICP params
    "vgicp_resolution": 0.5,
    "vgicp_voxelmap_levels": 1,
    "vgicp_voxelmap_scaling_factor": 2.0,
    // Optimizer params
    "validate_imu": true,
    "save_imu_rate_trajectory": true,
    "num_threads": 2
  }
}